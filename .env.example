# =============================================
# FINANZAPP — Variables de Entorno (EJEMPLO)
# Copia este archivo como .env y llena los valores.
# NUNCA subas el .env real al repositorio.
# =============================================

# ── Supabase (cliente — se puede exponer, protegido por RLS) ──
EXPO_PUBLIC_SUPABASE_URL=https://TU_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# ── Google OAuth (solo el Client ID — el Secret va en el servidor) ──
EXPO_PUBLIC_GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com

# ── Las siguientes variables son SOLO para scripts de admin local ──
# ── JAMÁS deben llegar a la app del cliente ──
# DB_POOLER_PASSWORD=tu_password_aqui
# GOOGLE_CLIENT_SECRET=tu_secret_aqui
